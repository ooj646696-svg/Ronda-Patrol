{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.10:8000/api",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.1.10:8000/ws"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.10:8000/api",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.1.10:8000/ws"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ronda-patrol-monitoring-web-app.onrender.com/api",
        "EXPO_PUBLIC_WS_URL": "wss://ronda-patrol-monitoring-web-app.onrender.com/ws"
      }
    }
  }
}